// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLINICIAN
  PATIENT
  ADMIN
}

enum ProductCategory {
  SUPPLEMENTS
  DEVICES
  COSMETIC
  DENTAL
  APPS
  WEARABLES
  OTHER
}

enum RecommendationStatus {
  SENT
  VIEWED
  PURCHASED
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum FulfillmentType {
  PHYSICAL
  DIGITAL
  AFFILIATE
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String?   @unique
  name          String?
  role          Role      @default(PATIENT)
  onboarded     Boolean   @default(false)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  doctorProfile   DoctorProfile?
  recommendations Recommendation[] @relation("DoctorRecommendations")
  receivedRecs    Recommendation[] @relation("PatientRecommendations")
  orders          Order[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Practice {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  specialty   String?
  description String?
  logoUrl     String?
  createdAt   DateTime @default(now())

  doctors  DoctorProfile[]
  products Product[]

  @@map("practices")
}

model DoctorProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  practiceId  String?
  displayName String
  specialty   String?
  npi         String?
  slug        String  @unique
  bio               String?
  avatarUrl         String?
  customCategories  String[]  @default([])

  user      User      @relation(fields: [userId], references: [id])
  practice  Practice? @relation(fields: [practiceId], references: [id])
  recommendations Recommendation[]
  protocols       Protocol[]
  picks           ClinicianPickedProduct[]
  kits            Kit[]
  kitFavorites    KitFavorite[]

  @@map("doctor_profiles")
}

model Product {
  id             String          @id @default(cuid())
  name           String
  brand          String
  imageUrl       String?
  price          Float
  affiliateUrl   String?
  sku            String?
  hsaFsaEligible    Boolean         @default(false)
  category          ProductCategory
  fulfillmentType   FulfillmentType @default(PHYSICAL)
  ctaLabel          String?
  amazonUrl         String?         // full Amazon product URL for Rainforest scan
  walmartUrl        String?         // full Walmart product URL for Rainforest scan
  manualFulfillment Boolean         @default(false) // true = not scanned by Rainforest, not fulfilled by Zinc
  tags              String[]
  description       String?
  practiceId        String?
  createdAt         DateTime        @default(now())

  practice           Practice?           @relation(fields: [practiceId], references: [id])
  recommendationItems RecommendationItem[]
  protocolItems      ProtocolItem[]
  orderItems         OrderItem[]
  picks              ClinicianPickedProduct[]
  retailerPrices     ProductRetailerPrice[]
  kitItems           KitItem[]

  @@index([category, name])
  @@map("products")
}

model ProductRetailerPrice {
  id                String    @id @default(cuid())
  productId         String
  retailer          String    // "amazon" | "walmart" | "manual"
  price             Decimal   @db.Decimal(10, 2)
  url               String
  retailerProductId String?   // ASIN for Amazon, item ID for Walmart
  available         Boolean   @default(true)
  manualEntry       Boolean   @default(false) // true = set by admin, never overwritten by Rainforest
  scannedAt         DateTime? // null when manualEntry = true
  updatedAt         DateTime  @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, retailer])
  @@map("product_retailer_prices")
}

model ClinicianPickedProduct {
  id          String   @id @default(cuid())
  clinicianId String
  productId   String
  createdAt   DateTime @default(now())

  clinician DoctorProfile @relation(fields: [clinicianId], references: [id])
  product   Product       @relation(fields: [productId], references: [id])

  @@unique([clinicianId, productId])
  @@map("clinician_picked_products")
}

model Recommendation {
  id                String               @id @default(cuid())
  token             String               @unique
  doctorId          String?
  doctorProfileId   String?
  patientId         String?
  patientIdentifier String?
  status            RecommendationStatus @default(SENT)
  note              String?
  createdAt         DateTime             @default(now())
  viewedAt          DateTime?
  purchasedAt       DateTime?

  doctor        User?          @relation("DoctorRecommendations", fields: [doctorId], references: [id])
  doctorProfile DoctorProfile? @relation(fields: [doctorProfileId], references: [id])
  patient       User?         @relation("PatientRecommendations", fields: [patientId], references: [id])
  items         RecommendationItem[]
  order         Order?

  @@map("recommendations")
}

model RecommendationItem {
  id               String @id @default(cuid())
  recommendationId String
  productId        String
  quantity         Int    @default(1)

  recommendation Recommendation @relation(fields: [recommendationId], references: [id])
  product        Product        @relation(fields: [productId], references: [id])

  @@map("recommendation_items")
}

model Order {
  id               String      @id @default(cuid())
  recommendationId String      @unique
  patientId        String
  total            Float
  status           OrderStatus @default(PENDING)
  stripeSessionId   String?
  retailer          String?
  zincOrderId       String?
  estimatedDelivery DateTime?
  trackingUrl       String?
  createdAt         DateTime    @default(now())

  recommendation Recommendation @relation(fields: [recommendationId], references: [id])
  patient        User           @relation(fields: [patientId], references: [id])
  items          OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model Protocol {
  id              String   @id @default(cuid())
  doctorProfileId String
  name            String
  description     String?
  createdAt       DateTime @default(now())

  doctorProfile DoctorProfile  @relation(fields: [doctorProfileId], references: [id])
  items         ProtocolItem[]

  @@map("protocols")
}

model ProtocolItem {
  id         String @id @default(cuid())
  protocolId String
  productId  String
  quantity   Int    @default(1)

  protocol Protocol @relation(fields: [protocolId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@map("protocol_items")
}

model Kit {
  id              String   @id @default(cuid())
  name            String
  doctorProfileId String?
  specialty       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  doctorProfile DoctorProfile? @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  items         KitItem[]
  favorites     KitFavorite[]

  @@map("kits")
}

model KitItem {
  id        String @id @default(cuid())
  kitId     String
  productId String
  order     Int    @default(0)

  kit     Kit     @relation(fields: [kitId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([kitId, productId])
  @@map("kit_items")
}

model KitFavorite {
  id              String   @id @default(cuid())
  doctorProfileId String
  kitId           String
  createdAt       DateTime @default(now())

  doctorProfile DoctorProfile @relation(fields: [doctorProfileId], references: [id], onDelete: Cascade)
  kit           Kit           @relation(fields: [kitId], references: [id], onDelete: Cascade)

  @@unique([doctorProfileId, kitId])
  @@map("kit_favorites")
}
